{
    "name": "mailcow-rest-api",
    "version": "0.5.14",
    "description": "Mailcow add-on REST API, OpenAPI UI, and optional MCP server for mailbox, send, calendar, drive, push, and account workflows.",
    "main": "src/server.js",
    "files": [
        "src/",
        "bin/",
        "README.md",
        "LICENSE"
    ],
    "engines": {
        "node": ">=20"
    },
    "scripts": {
        "start": "node src/server.js",
        "dev": "node --watch src/server.js",
        "mcp": "node src/mcp/index.js",
        "test": "node --test --test-concurrency=1 test/unit/*.test.js"
    },
    "bin": {
        "imap-rest-mcp": "bin/imap-rest-mcp"
    },
    "keywords": [
        "imap",
        "mailcow",
        "rest",
        "addon",
        "ocr",
        "mistral",
        "mcp",
        "model-context-protocol"
    ],
    "license": "MIT",
    "author": "John Rowe",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/jr551/mailcow-rest-api.git"
    },
    "bugs": {
        "url": "https://github.com/jr551/mailcow-rest-api/issues"
    },
    "homepage": "https://github.com/jr551/mailcow-rest-api#readme",
    "dependencies": {
        "@fastify/sensible": "6.0.4",
        "@fastify/static": "^8.2.0",
        "@fastify/swagger": "^9.7.0",
        "@fastify/swagger-ui": "^5.2.6",
        "@modelcontextprotocol/sdk": "1.29.0",
        "better-sqlite3": "12.9.0",
        "dotenv": "^17.4.2",
        "fast-xml-parser": "^5.7.2",
        "fastify": "5.8.5",
        "imapflow": "1.3.3",
        "mysql2": "^3.22.3",
        "nodemailer": "^8.0.7",
        "pino": "10.3.1",
        "undici": "7.25.0",
        "web-push": "^3.6.7",
        "zod": "4.3.6"
    },
    "devDependencies": {
        "pino-pretty": "13.1.3",
        "puppeteer-core": "^24.42.0"
    }
}
