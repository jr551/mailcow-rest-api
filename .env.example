# imap-rest-mailcow — example configuration
# Copy to .env and edit. All values shown are defaults.

# HTTP server
PORT=3001
HOST=0.0.0.0
BIND_ADDR=127.0.0.1     # set to 0.0.0.0 only for direct (non-proxied) exposure

# IMAP backend (mailcow Dovecot)
IMAP_HOST=dovecot-mailcow
IMAP_PORT=993
IMAP_SECURE=true
IMAP_TLS_SERVERNAME=
IMAP_TLS_REJECT_UNAUTHORIZED=true

# Auth cache (SQLite WAL)
CACHE_PATH=/data/cache.db
CACHE_TTL_VALID_MS=300000
CACHE_TTL_INVALID_MS=10000

# IMAP connection pool
POOL_MAX=50
POOL_IDLE_MS=30000

# Optional TLS (point at mailcow's existing certs to terminate TLS in this addon)
# TLS_CERT=/opt/mailcow-dockerized/data/assets/ssl/cert.pem
# TLS_KEY=/opt/mailcow-dockerized/data/assets/ssl/key.pem

# Mailcow network override (only needed if mailcow renames its network)
MAILCOW_NETWORK=mailcowdockerized_mailcow-network

# Mistral OCR + AI (one MISTRAL_API_KEY powers both OCR and AI summarize/draft).
# Leave unset to disable the OCR endpoint and the /v1/ai/* endpoints.
# MISTRAL_API_KEY=
# MISTRAL_OCR_MODEL=mistral-ocr-latest
# MISTRAL_OCR_TIMEOUT_MS=60000
# MISTRAL_CHAT_MODEL=mistral-small-latest
# MISTRAL_CHAT_TIMEOUT_MS=30000
# MISTRAL_CHAT_MAX_INPUT_CHARS=24000

# ElevenLabs text-to-speech (voice replies in the webmail AI chat).
# Leave unset to disable spoken replies (voice mode still works as text-only).
# ELEVENLABS_API_KEY=

# Webmail SPA (Svelte). Default: enabled, served at /webmail/. Set to false to
# disable the static mount entirely (e.g., if you don't ship the dist).
# WEBMAIL_ENABLED=true
# WEBMAIL_DIST=/app/webmail/dist

# SMTP send configuration.
# Requires SMTP_HOST to be set. Uses the user's IMAP credentials for SMTP AUTH.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# OCR result cache (content-addressable, separate SQLite file).
# Key = sha256(attachment_bytes) + model. No TTL — OCR is deterministic.
# OCR_CACHE_ENABLED=true
# OCR_CACHE_PATH=/data/ocr-cache.db
# OCR_CACHE_MAX_ENTRIES=1000

# Web Push subscription store (separate SQLite file).
# PUSH_DB_PATH=/data/push.db

# Open/click tracking store (separate SQLite file).
# TRACKING_DB_PATH=/data/tracking.db

# Session lifetime cap. Sliding TTL (CACHE_TTL_VALID_MS) extends idle sessions,
# but a hard cap forces re-auth after this many ms regardless of activity.
# SESSION_MAX_LIFETIME_MS=86400000

# Network access
# Optional comma-separated allowlist of CIDRs / IPs allowed to reach the API.
# Empty (default) = allow all. 127.0.0.1 and ::1 are always allowed so the
# Docker healthcheck cannot lock itself out.
# IP_ALLOWLIST=
# Honor X-Forwarded-For from upstream proxies (default: true). Set to false
# only if the addon is exposed directly to clients without a proxy.
# TRUST_PROXY=true

# SOGo CalDAV (optional — leave SOGO_URL unset to disable calendar endpoints)
# SOGO_URL=http://nginx-mailcow/SOGo
# CALDAV_TLS_REJECT_UNAUTHORIZED=true

# S3 Drive (optional client-side file manager)
# Set S3_DRIVE_ENABLED=true and choose a provider:
#   'json'  — static per-user config from a JSON file (see config/drive-users.example.json)
#   'b2'    — Backblaze B2 auto-provisioning (creates buckets + keys per user on demand)
# S3_DRIVE_ENABLED=false
# S3_DRIVE_PROVIDER=json
# S3_DRIVE_USERS_JSON=./data/drive-users.json
# S3_DRIVE_DEFAULT_QUOTA_GB=5

# Backblaze B2 master key (only used when S3_DRIVE_PROVIDER=b2)
# The server uses this to authorize with B2, create private buckets, and issue
# per-user application keys scoped to a single bucket.
# B2_KEY_ID=***REDACTED_B2_ID***
# B2_APPLICATION_KEY=***REDACTED_B2_APP***

# Logging
LOG_LEVEL=info

# MCP server (only used when running `npm run mcp` or the `imap-rest-mcp` bin)
# Tells the MCP server where the REST API lives and which mailcow account it
# should authenticate as. Not consumed by the REST server itself.
# IMAP_REST_BASE_URL=http://127.0.0.1:3001
# IMAP_REST_USER=user@example.com
# IMAP_REST_PASS=
# IMAP_REST_TIMEOUT_MS=90000
